# LLM provider key. pydantic-ai picks it up automatically when the
# pydanticai_default connection leaves the password blank.
OPENAI_API_KEY=

# common-ai durable agent cache (ObjectStoragePath URI). Required when any DAG
# uses durable=True on @task.agent / AgentOperator. See:
# https://airflow.apache.org/docs/apache-airflow-providers-common-ai/stable/_api/airflow/providers/common/ai/durable/storage/index.html
AIRFLOW__COMMON_AI__DURABLE_CACHE_PATH=file:///tmp/airflow_durable_cache

# Airflow connections (JSON form). Docs:
# https://airflow.apache.org/docs/apache-airflow/stable/authoring-and-scheduling/connections.html#json-format
# One connection per line; Airflow strips AIRFLOW_CONN_ and lowercases the rest.

AIRFLOW_CONN_PYDANTICAI_DEFAULT={"conn_type": "pydanticai", "extra": {"model": "openai:gpt-5-mini"}}

# AIRFLOW__API__BASE_URL cannot be set from .env — Astro CLI's generated compose
# hard-codes it to http://localhost:8080, which overrides both .env and
# Dockerfile ENV. See docker-compose.override.yml in this repo for the fix that
# lets the HITL Review React plugin load its JS bundle from the right origin.

AIRFLOW_CONN_MCP_DEFAULT={"conn_type": "mcp", "host": "http://localhost:3001/mcp", "extra": {"transport": "http"}}

AIRFLOW_CONN_MCP_STDIO_SPACE={"conn_type": "mcp", "extra": {"transport": "stdio", "command": "python", "args": ["/usr/local/airflow/include/mcp_server/space_server.py"]}}

AIRFLOW_CONN_SPACE_LOGISTICS={"conn_type": "sqlite", "host": "/tmp/space_logistics.db"}

AIRFLOW_CONN_SPACE_LOGISTICS_ALT={"conn_type": "sqlite", "host": "/tmp/space_logistics_alt.db"}

AIRFLOW_CONN_FIXTURES_FS={"conn_type": "fs", "extra": {"path": "/usr/local/airflow/include/fixtures"}}
